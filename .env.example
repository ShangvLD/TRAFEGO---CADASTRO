# Copie este arquivo para ".env" e ajuste os valores.
# O .env NÃO deve ser versionado (já está no .gitignore).

# Porta em que o servidor vai rodar (só no desenvolvimento local)
PORT=3000

# ---------------------------------------------------------------------------
# Banco de dados
# ---------------------------------------------------------------------------
# DESENVOLVIMENTO LOCAL: deixe as duas variáveis abaixo em branco. O app usa
# um arquivo SQLite local em ./data/trafego.db (rápido, offline).
#
# PRODUÇÃO (Vercel): defina as duas com os valores do Turso. Pegue com:
#   turso db show trafego-cadastro --url      -> TURSO_DATABASE_URL
#   turso db tokens create trafego-cadastro   -> TURSO_AUTH_TOKEN
# No Vercel, estas variáveis vão em Settings > Environment Variables (NÃO aqui).
# TURSO_DATABASE_URL=libsql://trafego-cadastro-SEU-USUARIO.turso.io
# TURSO_AUTH_TOKEN=

# (Opcional) Pasta do banco local no dev. Em branco = ./data.
# DATA_DIR=

# Segredo usado para assinar os cookies de sessão.
# Troque por um valor longo e aleatório em produção.
SESSION_SECRET=troque-este-valor-por-um-segredo-longo-e-aleatorio

# Segredo compartilhado com o Power Automate para o webhook do Microsoft Forms.
# O Power Automate deve enviá-lo no cabeçalho "x-webhook-secret" a cada resposta.
# Enquanto estiver vazio/ausente, o webhook fica DESLIGADO (retorna 503).
# Gere um valor longo e aleatório (ex.: no PowerShell: [guid]::NewGuid().ToString()).
FORMS_WEBHOOK_SECRET=troque-por-um-segredo-longo-e-aleatorio
